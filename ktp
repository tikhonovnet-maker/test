          <div class="tmodal-section-title">Ключевые вопросы</div>
          <div class="tmodal-questions">${t.questions.map(q => `<div class="tmodal-q">${q}</div>`).join('')}</div>
        </div>
        <div class="tmodal-section">
          <div class="tmodal-section-title">Рекомендации психологу</div>
          <div class="tmodal-tips">${t.tips.map(tip => `<div class="tmodal-tip">${tip}</div>`).join('')}</div>
        </div>
        <div class="tmodal-section">
          <div class="tmodal-section-title">Применяется при</div>
          <div class="tmodal-tags">${t.tags.map(tag => `<span class="tmodal-tag">${tag}</span>`).join('')}</div>
        </div>
      </div>`;
    document.getElementById('tmodal-overlay').classList.add('open');
  },

  closeTModal() { document.getElementById('tmodal-overlay').classList.remove('open'); },
};

// ═════════════════════════════════════════════════════════════════════════════════════
// CALENDAR CONTROLLER — Календарь и расписание
// ═════════════════════════════════════════════════════════════════════════════════════

const CalendarController = {
  calY: 0, calM: 0, calDay: '',
  MONTHS: ['Январь','Февраль','Март','Апрель','Май','Июнь','Июль','Август','Сентябрь','Октябрь','Ноябрь','Декабрь'],
  WDS: ['Пн','Вт','Ср','Чт','Пт','Сб','Вс'],

  openCalendar() {
    const now = new Date(); this.calY = now.getFullYear(); this.calM = now.getMonth();
    this.renderCal();
    NavController.navTo('s-calendar');
  },
  calToday() { const n = new Date(); this.calY = n.getFullYear(); this.calM = n.getMonth(); this.renderCal(); },
  calMove(d) { this.calM += d; if (this.calM < 0) { this.calM = 11; this.calY--; } if (this.calM > 11) { this.calM = 0; this.calY++; } this.renderCal(); },

  renderCal() {
    document.getElementById('cal-month').textContent = `${this.MONTHS[this.calM]} ${this.calY}`;
    const today = new Date();
    let html = this.WDS.map((d, i) => `<div class="cal-wd${i >= 5 ? ' wknd' : ''}">${d}</div>`).join('');
    let dow = new Date(this.calY, this.calM, 1).getDay(); dow = dow === 0 ? 6 : dow - 1;
    const dim = new Date(this.calY, this.calM + 1, 0).getDate();
    const dip = new Date(this.calY, this.calM, 0).getDate();
    const total = Math.ceil((dow + dim) / 7) * 7;
    for (let i = 0; i < total; i++) {
      let day, mo, yr, other = false;
      if (i < dow) { day = dip - dow + i + 1; mo = this.calM - 1; yr = this.calY; if (mo < 0) { mo = 11; yr--; } other = true; }
      else if (i >= dow + dim) { day = i - dow - dim + 1; mo = this.calM + 1; yr = this.calY; if (mo > 11) { mo = 0; yr++; } other = true; }
      else { day = i - dow + 1; mo = this.calM; yr = this.calY; }
      const ds = `${yr}-${String(mo + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
      const isToday = !other && day === today.getDate() && mo === today.getMonth() && yr === today.getFullYear();
      const wknd = (dow + i) % 7 >= 5;
      const past = new Date(yr, mo, day) < new Date(today.getFullYear(), today.getMonth(), today.getDate());
      const evs = Storage.getAppointments().filter(a => a.date === ds).sort((a, b) => a.time.localeCompare(b.time));
      const evsH = evs.map(a => {
        const c = ClientController.clients[a.clientIdx];
        const nm = c ? `${c.name}${c.surname ? ' ' + c.surname[0] + '.' : ''}` : '?';
        const sn = 1;
        return `<div class="cal-ev${past ? ' past' : ''}"><span class="ev-n">#${sn}</span><span>${a.time} ${nm}</span></div>`;
      }).join('');
      html += `<div class="cal-cell${other ? ' other' : ''}${isToday ? ' today' : ''}${wknd ? ' wknd' : ''}"${other ? '' : ` onclick="CalendarController.openCalDay('${ds}')"`}>
        <div class="cal-dn">${day}</div>${evsH}</div>`;
    }
    document.getElementById('cal-grid').innerHTML = html;
  },

  openCalDay(ds) {
    this.calDay = ds;
    const d = new Date(ds + 'T12:00:00');
    document.getElementById('cal-side-hd').textContent = d.toLocaleDateString('ru-RU', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
    this.renderAppts();
    const sel = document.getElementById('cal-client');
    sel.innerHTML = ClientController.clients.length
      ? ClientController.clients.map((c, i) => `<option value="${i}">${c.name}${c.surname ? ' ' + c.surname : ''}</option>`).join('')
      : '<option value="">Нет клиентов</option>';
    document.getElementById('cal-overlay').classList.add('open');
  },

  renderAppts() {
    const list = Storage.getAppointments().filter(a => a.date === this.calDay).sort((a, b) => a.time.localeCompare(b.time));
    document.getElementById('cal-appt-list').innerHTML = list.length
      ? list.map(a => {
        const c = ClientController.clients[a.clientIdx];
        const nm = c ? `${c.name}${c.surname ? ' ' + c.surname : ''}` : 'Удалённый клиент';
        const sn = 1;
        const sc = Storage.getSessions().filter(s => s.clientIdx === a.clientIdx).length;
        return `<div class="appt-item">
          <div class="appt-time">${a.time}</div>
          <div class="appt-info"><div class="appt-name">${nm}</div><div class="appt-badge">Сессия <strong>#${sn}</strong> · завершено: ${sc}</div></div>
          <button class="appt-del" onclick="CalendarController.delAppt(${a.id})"><svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M18 6 6 18M6 6l12 12"/></svg></button>
        </div>`;
      }).join('')
      : '<div class="no-appts">Нет записей на этот день</div>';
  },

  addAppt() {
    const time = document.getElementById('cal-time').value;
    const ci = parseInt(document.getElementById('cal-client').value);
    if (!this.calDay || isNaN(ci) || !time) return;
    if (!Validators.isValidClientIndex(ci, ClientController.clients)) {
      UIController.showToast('❌ Клиент не выбран');
      return;
    }
    const appts = Storage.getAppointments();
    appts.push({id:Date.now(),date:this.calDay,time,clientIdx:ci});
    Storage.setAppointments(appts);
    this.renderAppts();
    this.renderCal();
  },

  delAppt(id) {
    const appts = Storage.getAppointments().filter(a => a.id !== id);
    Storage.setAppointments(appts);
    this.renderAppts();
    this.renderCal();
  },

  closeCalSide() { document.getElementById('cal-overlay').classList.remove('open'); },
  closeSideIfBg(e) { if (e.target.id === 'cal-overlay') this.closeCalSide(); },
};

// ═════════════════════════════════════════════════════════════════════════════════════
// ARCHIVE CONTROLLER — Архив клиентов
// ═════════════════════════════════════════════════════════════════════════════════════

const ArchiveController = {
  openArchive() {
    this.render();
    NavController.navTo('s-archive');
  },

  render() {
    const archived = ClientController.clients.filter(c => c.archived);
    document.getElementById('archive-count-label').textContent = `${archived.length} ${Helpers.declination(archived.length,'клиент','клиента','клиентов')}`;
    const g = document.getElementById('archive-grid');
    if (!archived.length) {
      g.innerHTML = `<div class="empty-state">
        <svg width="52" height="52" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M21 8v13a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8"/><path d="M1 3h22v5H1z"/></svg>
        <p>Архив пуст</p>
      </div>`;
      return;
    }
    g.innerHTML = archived.map((c, i) => {
      const idx = ClientController.clients.indexOf(c);
      const age = Validators.calculateAge(c.dob);
      const sc = Storage.getSessions().filter(s => s.clientIdx === idx).length;
      const archivedDate = c.archivedAt ? new Date(c.archivedAt).toLocaleDateString('ru-RU',{day:'numeric',month:'long',year:'numeric'}) : '';
      return `<div class="archive-card" onclick="ClientController.openClient(${idx})">
        <div class="client-avatar">${Helpers.ini(c)}</div>
        <div class="client-name">${c.name}${c.surname?' '+c.surname:''}</div>
        <div class="client-meta">${age?age+' лет · ':''}${Helpers.truncate(c.complaint||'Нет запроса',55)}</div>
        <div class="client-footer">
          <span>Сессий: <strong>${sc}</strong>${archivedDate?' · Архив: '+archivedDate:''}</span>
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg>
        </div>
      </div>`;
    }).join('');
  },
};

// ═════════════════════════════════════════════════════════════════════════════════════
// UI CONTROLLER — Управление интерфейсом
// ═════════════════════════════════════════════════════════════════════════════════════

const UIController = {
  openClientModal() { document.getElementById('client-modal').classList.add('open'); },
  closeClientModal() { document.getElementById('client-modal').classList.remove('open'); },
  closeModalIfBg(e) { if (e.target.id === 'client-modal') this.closeClientModal(); },
  closeTModalIfBg(e) { if (e.target.id === 'tmodal-overlay') TechniqueController.closeTModal(); },
  closeTestIfBg(e) { if (e.target.id === 'test-overlay') TestController.closeTest(); },
  closeConfirmIfBg(e) { if (e.target.id === 'confirm-overlay') this.closeConfirm(); },

  openSidebar() {
    const archived = ClientController.clients.filter(c=>c.archived).length;
    document.getElementById('sidebar-body').innerHTML = `
      <button class="sb-item" onclick="CalendarController.openCalendar();UIController.closeSidebar()">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
        Календарь сессий
      </button>
      <div class="sb-divider"></div>
      <div class="sb-section-label">Инструменты</div>
      <button class="sb-item" onclick="TechniqueController.openTechniquesRef();UIController.closeSidebar()">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
        Техники КПТ
      </button>
      <div class="sb-divider"></div>
      <div class="sb-section-label">Прочее</div>
      <button class="sb-item" onclick="ArchiveController.openArchive();UIController.closeSidebar()">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 8v13a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8"/><path d="M1 3h22v5H1z"/></svg>
        Архив ${archived > 0 ? `<span style="margin-left:auto;background:rgba(192,57,43,.15);color:var(--danger);font-size:11px;font-weight:700;padding:2px 8px;border-radius:50px">${archived}</span>` : ''}
      </button>
    `;
    document.getElementById('sidebar-overlay').classList.add('open');
  },

  closeSidebar() { document.getElementById('sidebar-overlay').classList.remove('open'); },

  showToast(msg) {
    let t = document.getElementById('save-toast');
    if (!t) {
      t = document.createElement('div');
      t.id = 'save-toast';
      t.style.cssText = 'position:fixed;bottom:90px;left:50%;transform:translateX(-50%) translateY(20px);background:var(--accent);color:#fff;padding:10px 22px;border-radius:50px;font-family:Golos Text,sans-serif;font-size:13px;font-weight:600;z-index:999;opacity:0;transition:all .3s;pointer-events:none;';
      document.body.appendChild(t);
    }
    t.textContent = msg;
    t.style.opacity = '1';
    t.style.transform = 'translateX(-50%) translateY(0)';
    clearTimeout(t._timer);
    t._timer = setTimeout(() => { t.style.opacity = '0'; t.style.transform = 'translateX(-50%) translateY(20px)'; }, 2200);
  },

  confirmArchive(idx) {
    const c = ClientController.clients[idx];
    const sc = Storage.getSessions().filter(s => s.clientIdx === idx).length;
    document.getElementById('confirm-icon').textContent = '📦';
    document.getElementById('confirm-title').textContent = `Перенести ${c.name} в архив?`;
    document.getElementById('confirm-text').innerHTML = `Клиент будет перемещён в архив.<br><strong>Все ${sc} ${Helpers.declination(sc,'сессия','сессии','сессий')} и данные сохранятся.</strong><br>Вы сможете вернуть клиента в любой момент.`;
    const btn = document.getElementById('confirm-ok-btn');
    btn.textContent = 'Перенести в архив';
    btn.style.cssText = 'background:var(--danger);color:#fff;padding:11px 22px;border-radius:50px;box-shadow:0 4px 14px rgba(192,57,43,.3)';
    btn.onclick = () => { this.archiveClient(idx); this.closeConfirm(); };
    document.getElementById('confirm-overlay').classList.add('open');
  },

  confirmRestore(idx) {
    const c = ClientController.clients[idx];
    document.getElementById('confirm-icon').textContent = '🔄';
    document.getElementById('confirm-title').textContent = `Вернуть ${c.name} в картотеку?`;
    document.getElementById('confirm-text').innerHTML = `Клиент будет возвращён в активную картотеку.<br><strong>Все данные и история сессий сохранены.</strong>`;
    const btn = document.getElementById('confirm-ok-btn');
    btn.textContent = 'Вернуть в картотеку';
    btn.style.cssText = 'background:var(--accent);color:#fff;padding:11px 22px;border-radius:50px;box-shadow:0 4px 14px rgba(45,90,61,.3)';
    btn.onclick = () => { this.restoreClient(idx); this.closeConfirm(); };
    document.getElementById('confirm-overlay').classList.add('open');
  },

  archiveClient(idx) {
    ClientController.clients[idx].archived = true;
    ClientController.clients[idx].archivedAt = new Date().toISOString();
    Storage.setClients(ClientController.clients);
    ClientController.render();
    NavController.navBack('s-clients');
    this.showToast(`${ClientController.clients[idx].name} перенесён(а) в архив 📦`);
  },

  restoreClient(idx) {
    ClientController.clients[idx].archived = false;
    delete ClientController.clients[idx].archivedAt;
    Storage.setClients(ClientController.clients);
    ClientController.render();
    ArchiveController.render();
    ClientController.openClient(idx);
    this.showToast(`${ClientController.clients[idx].name} возвращён(а) в картотеку ✓`);
  },

  closeConfirm() { document.getElementById('confirm-overlay').classList.remove('open'); },
};

