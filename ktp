<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>КПТшка</title>
<link href="https://fonts.googleapis.com/css2?family=Unbounded:wght@300;400;600&family=Golos+Text:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #f0ede8;
  --surface: #faf8f5;
  --surface2: #e8e4dd;
  --accent: #2d5a3d;
  --accent2: #7ab08a;
  --accent3: #c8b89a;
  --text: #1a1a18;
  --text2: #6b6860;
  --text3: #a8a49e;
  --danger: #c0392b;
  --shadow: 0 2px 12px rgba(0,0,0,0.06), 0 1px 3px rgba(0,0,0,0.04);
  --shadow-hover: 0 8px 32px rgba(0,0,0,0.12), 0 2px 8px rgba(0,0,0,0.06);
  --r: 16px;
  --r-sm: 10px;
  --ease: 0.3s cubic-bezier(0.4,0,0.2,1);
}
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
html, body { height:100%; font-family:'Golos Text',sans-serif; background:var(--bg); color:var(--text); overflow:hidden; }

.screen {
  position:fixed; inset:0;
  display:flex; flex-direction:column;
  background:var(--bg);
  transform:translateX(100%);
  transition:transform var(--ease);
  will-change:transform;
}
.screen.active  { transform:translateX(0); }
.screen.behind  { transform:translateX(-40px); }

.screen-body {
  flex:1;
  overflow-y:auto;
  overflow-x:hidden;
  padding:0 32px 60px;
}

.topbar {
  display:flex; align-items:center; gap:14px;
  padding:16px 32px;
  background:var(--bg);
  border-bottom:1px solid var(--surface2);
  flex-shrink:0;
}
.logo { font-family:'Unbounded',sans-serif; font-size:17px; font-weight:600; color:var(--accent); letter-spacing:-.5px; }
.logo span { color:var(--text3); font-weight:300; }
.spacer { flex:1; }
.back-btn {
  width:34px; height:34px; border-radius:50%;
  background:var(--surface2); border:none; cursor:pointer;
  display:flex; align-items:center; justify-content:center;
  color:var(--text); flex-shrink:0;
  transition:background var(--ease), transform .15s;
}
.back-btn:hover { background:var(--accent2); color:#fff; transform:translateX(-2px); }
.topbar-title { font-family:'Unbounded',sans-serif; font-size:13px; font-weight:400; color:var(--text2); }

.btn-primary {
  display:inline-flex; align-items:center; gap:8px;
  background:var(--accent); color:#fff;
  border:none; border-radius:50px; padding:11px 20px;
  font-family:'Golos Text',sans-serif; font-size:14px; font-weight:600;
  cursor:pointer; white-space:nowrap;
  box-shadow:0 4px 16px rgba(45,90,61,.25);
  transition:background var(--ease), transform .15s;
}
.btn-primary:hover { background:#234830; transform:translateY(-1px); }

.btn-secondary {
  display:inline-flex; align-items:center; gap:8px;
  background:var(--surface); color:var(--accent);
  border:2px solid var(--surface2); border-radius:50px; padding:9px 18px;
  font-family:'Golos Text',sans-serif; font-size:14px; font-weight:500;
  cursor:pointer; white-space:nowrap;
  transition:background var(--ease), border-color var(--ease);
}
.btn-secondary:hover { background:var(--surface2); border-color:var(--accent2); }

.btn-ghost {
  padding:11px 20px; border-radius:50px;
  border:2px solid var(--surface2); background:transparent;
  font-family:'Golos Text',sans-serif; font-size:14px; font-weight:500; color:var(--text2);
  cursor:pointer; transition:border-color var(--ease), color var(--ease);
}
.btn-ghost:hover { border-color:var(--text3); color:var(--text); }

.page-header {
  padding:22px 0 18px;
  display:flex; align-items:flex-end; justify-content:space-between; gap:16px;
}
.page-title { font-family:'Unbounded',sans-serif; font-size:26px; font-weight:600; line-height:1.2; }
.page-subtitle { font-size:13px; color:var(--text3); margin-top:5px; }

.search-wrap { position:relative; margin-bottom:18px; }
.search-wrap svg { position:absolute; left:15px; top:50%; transform:translateY(-50%); color:var(--text3); pointer-events:none; }
.search-input {
  width:100%; padding:12px 15px 12px 44px; border-radius:50px;
  border:2px solid transparent; background:var(--surface);
  font-family:'Golos Text',sans-serif; font-size:14px; color:var(--text);
  outline:none; box-shadow:var(--shadow);
  transition:border-color var(--ease), box-shadow var(--ease);
}
.search-input:focus { border-color:var(--accent2); box-shadow:0 0 0 4px rgba(122,176,138,.15); }
.search-input::placeholder { color:var(--text3); }

@keyframes fadeUp { from{opacity:0;transform:translateY(14px)} to{opacity:1;transform:translateY(0)} }

.client-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(270px,1fr)); gap:14px; }
.client-card {
  background:var(--surface); border-radius:var(--r); padding:20px;
  cursor:pointer; border:2px solid transparent; box-shadow:var(--shadow);
  animation:fadeUp .35s ease both;
  transition:border-color var(--ease), box-shadow var(--ease), transform var(--ease);
}
.client-card:hover { border-color:var(--accent2); box-shadow:var(--shadow-hover); transform:translateY(-3px); }

.client-avatar {
  width:46px; height:46px; border-radius:50%;
  background:linear-gradient(135deg,var(--accent2),var(--accent));
  display:flex; align-items:center; justify-content:center;
  font-family:'Unbounded',sans-serif; font-size:15px; font-weight:600; color:#fff;
  margin-bottom:12px;
}
.client-name { font-family:'Unbounded',sans-serif; font-size:13px; font-weight:600; margin-bottom:3px; }
.client-meta { font-size:12px; color:var(--text3); margin-bottom:12px; }
.tags { display:flex; flex-wrap:wrap; gap:5px; }
.tag { font-size:11px; font-weight:500; padding:3px 9px; border-radius:50px; background:var(--surface2); color:var(--text2); white-space:nowrap; }
.tag.green { background:rgba(122,176,138,.2); color:var(--accent); }
.client-footer { display:flex; align-items:center; justify-content:space-between; margin-top:14px; padding-top:12px; border-top:1px solid var(--surface2); font-size:12px; color:var(--text3); }
.client-footer strong { color:var(--text2); font-weight:600; }
.empty-state { text-align:center; padding:70px 0; color:var(--text3); grid-column:1/-1; }
.empty-state svg { margin-bottom:14px; opacity:.3; }
.empty-state p { font-size:14px; }

.profile-hero {
  display:flex; align-items:center; gap:16px; flex-wrap:wrap;
  padding:20px 0 22px; border-bottom:1px solid var(--surface2); margin-bottom:24px;
}
.profile-hero-info { flex:1; min-width:0; }
.profile-avatar {
  width:68px; height:68px; border-radius:50%;
  background:linear-gradient(135deg,var(--accent2),var(--accent));
  display:flex; align-items:center; justify-content:center;
  font-family:'Unbounded',sans-serif; font-size:22px; font-weight:600; color:#fff; flex-shrink:0;
}
.profile-name { font-family:'Unbounded',sans-serif; font-size:20px; font-weight:600; margin-bottom:3px; }
.profile-sub { font-size:13px; color:var(--text3); }
.btn-session {
  display:inline-flex; align-items:center; gap:8px;
  background:var(--accent); color:#fff; border:none; border-radius:50px;
  padding:12px 20px; font-family:'Golos Text',sans-serif; font-size:14px; font-weight:600;
  cursor:pointer; margin-left:auto; flex-shrink:0;
  box-shadow:0 4px 20px rgba(45,90,61,.3);
  transition:background var(--ease), transform .15s;
}
.btn-session:hover { background:#234830; transform:translateY(-2px); }

.section-title { font-family:'Unbounded',sans-serif; font-size:11px; font-weight:600; color:var(--accent); margin:26px 0 12px; letter-spacing:.3px; }
.fields-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(270px,1fr)); gap:10px; }
.field-card { background:var(--surface); border-radius:var(--r-sm); padding:14px 16px; box-shadow:var(--shadow); animation:fadeUp .3s ease both; }
.field-card.wide { grid-column:1/-1; }
.field-label { font-size:10px; font-weight:600; text-transform:uppercase; letter-spacing:.8px; color:var(--text3); margin-bottom:5px; }
.field-value { font-size:13px; color:var(--text); line-height:1.5; }
.field-value.empty { color:var(--text3); font-style:italic; }

.session-item { background:var(--surface); border-radius:var(--r-sm); padding:13px 16px; margin-bottom:8px; box-shadow:var(--shadow); border:2px solid transparent; animation:fadeUp .3s ease both; transition:border-color var(--ease); }
.session-item:hover { border-color:var(--accent2); }
.session-item-head { display:flex; align-items:center; justify-content:space-between; margin-bottom:6px; }
.session-item-date { font-family:'Unbounded',sans-serif; font-size:11px; font-weight:600; }
.session-item-badge { font-size:10px; font-weight:600; color:var(--accent); background:rgba(45,90,61,.1); padding:2px 8px; border-radius:50px; }
.session-item-techs { display:flex; flex-wrap:wrap; gap:4px; margin-bottom:5px; }
.session-item-techs .tag { font-size:10px; padding:2px 7px; }
.session-item-note { font-size:11px; color:var(--text3); line-height:1.4; }
.no-sessions { text-align:center; padding:20px; color:var(--text3); font-size:13px; background:var(--surface); border-radius:var(--r-sm); border:2px dashed var(--surface2); }

.technique-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:12px; }

.tc-wrap {
  perspective: 900px;
  min-height: 155px;
  animation: fadeUp .35s ease both;
  cursor: pointer;
}

.tc-inner {
  width:100%; height:100%; min-height:155px;
  position:relative;
  transform-style: preserve-3d;
  transition: transform 0.55s cubic-bezier(0.4,0,0.2,1);
}
.tc-wrap.flipped .tc-inner { transform: rotateY(180deg); }

.tc-front, .tc-back {
  position:absolute; inset:0;
  border-radius:var(--r); padding:18px;
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
  display:flex; flex-direction:column;
  border: 2px solid transparent;
  box-shadow: var(--shadow);
}

.tc-front {
  background: var(--surface);
  transition: border-color var(--ease), box-shadow var(--ease);
}
.tc-wrap:hover .tc-front { border-color:var(--accent2); box-shadow:var(--shadow-hover); }

.tc-back {
  background: linear-gradient(135deg, var(--accent), #1a3d28);
  transform: rotateY(180deg);
  border-color: transparent;
  align-items: center; justify-content: center;
}
.tc-back-icon { font-size: 36px; opacity:.9; }

.technique-num { font-family:'Unbounded',sans-serif; font-size:10px; font-weight:600; color:var(--text3); margin-bottom:8px; }
.technique-name { font-family:'Unbounded',sans-serif; font-size:11px; font-weight:600; color:var(--text); margin-bottom:8px; line-height:1.35; flex:1; }
.technique-desc { font-size:10px; color:var(--text3); line-height:1.5; }
.technique-icon { position:absolute; bottom:12px; right:12px; width:26px; height:26px; border-radius:50%; background:var(--surface2); display:flex; align-items:center; justify-content:center; font-size:13px; transition:background var(--ease); }
.tc-wrap:hover .technique-icon { background:var(--accent2); }

.tmodal-overlay {
  position:fixed; inset:0;
  background: rgba(26,26,24,0.5);
  backdrop-filter: blur(6px);
  z-index: 600;
  display:flex; align-items:center; justify-content:center;
  padding: 24px;
  opacity:0; pointer-events:none;
  transition: opacity 0.3s;
}
.tmodal-overlay.open { opacity:1; pointer-events:all; }

.tmodal {
  background: var(--surface);
  border-radius: 22px;
  width: 100%; max-width: 680px;
  max-height: 85vh; overflow-y: auto; overflow-x: hidden;
  box-shadow: 0 32px 96px rgba(0,0,0,0.22);
  transform: scale(0.93) translateY(20px);
  transition: transform 0.4s cubic-bezier(0.34,1.2,0.64,1), opacity 0.3s;
  opacity: 0;
}
.tmodal-overlay.open .tmodal { transform: scale(1) translateY(0); opacity:1; }

.tmodal-hero {
  background: linear-gradient(135deg, var(--accent), #1a3d28);
  border-radius: 22px 22px 0 0;
  padding: 28px 28px 24px;
  display:flex; align-items:flex-start; gap:16px;
  position: relative;
}
.tmodal-hero-icon { font-size: 44px; line-height:1; flex-shrink:0; }
.tmodal-hero-text { flex:1; }
.tmodal-num { font-family:'Unbounded',sans-serif; font-size:11px; font-weight:600; color:rgba(255,255,255,0.5); margin-bottom:6px; letter-spacing:.5px; }
.tmodal-title { font-family:'Unbounded',sans-serif; font-size:20px; font-weight:600; color:#fff; line-height:1.2; margin-bottom:8px; }
.tmodal-tagline { font-size:13px; color:rgba(255,255,255,0.75); line-height:1.5; }
.tmodal-close {
  position:absolute; top:18px; right:18px;
  width:32px; height:32px; border-radius:50%;
  border:none; background:rgba(255,255,255,0.15);
  cursor:pointer; display:flex; align-items:center; justify-content:center;
  color:#fff; transition:background .2s;
}
.tmodal-close:hover { background:rgba(255,255,255,0.3); }

.tmodal-body { padding: 24px 28px 28px; }

.tmodal-section { margin-bottom: 22px; }
.tmodal-section-title {
  font-family:'Unbounded',sans-serif; font-size:11px; font-weight:600;
  color:var(--accent); text-transform:uppercase; letter-spacing:.8px;
  margin-bottom:12px;
}

.tmodal-steps { display:flex; flex-direction:column; gap:10px; }
.tmodal-step {
  display:flex; gap:12px; align-items:flex-start;
  background:var(--bg); border-radius:var(--r-sm); padding:12px 14px;
}
.tmodal-step-num {
  font-family:'Unbounded',sans-serif; font-size:11px; font-weight:600;
  color:#fff; background:var(--accent); border-radius:6px;
  width:22px; height:22px; display:flex; align-items:center; justify-content:center;
  flex-shrink:0; margin-top:1px;
}
.tmodal-step-text { font-size:13px; color:var(--text); line-height:1.5; }

.tmodal-tips { display:flex; flex-direction:column; gap:8px; }
.tmodal-tip {
  display:flex; gap:10px; align-items:flex-start;
  font-size:13px; color:var(--text2); line-height:1.5;
}
.tmodal-tip::before { content:'→'; color:var(--accent2); font-weight:700; flex-shrink:0; margin-top:1px; }

.tmodal-questions { display:flex; flex-direction:column; gap:8px; }
.tmodal-q {
  background: rgba(122,176,138,0.1);
  border-left: 3px solid var(--accent2);
  border-radius: 0 var(--r-sm) var(--r-sm) 0;
  padding: 10px 14px;
  font-size:13px; color:var(--text); line-height:1.5; font-style:italic;
}

.tmodal-tags { display:flex; flex-wrap:wrap; gap:6px; }
.tmodal-tag { font-size:12px; font-weight:500; padding:5px 12px; border-radius:50px; background:var(--surface2); color:var(--text2); }

.session-bar {
  position:fixed; bottom:0; left:0; right:0;
  background:var(--bg); border-top:1px solid var(--surface2);
  padding:12px 32px; display:flex; align-items:center; gap:12px; z-index:200;
  transform:translateY(100%); transition:transform var(--ease);
}
.session-bar.show { transform:translateY(0); }
.bar-count { font-size:13px; color:var(--text2); white-space:nowrap; }
.bar-count strong { color:var(--accent); }
.bar-note { flex:1; padding:9px 15px; border-radius:50px; border:2px solid var(--surface2); background:var(--surface); font-family:'Golos Text',sans-serif; font-size:13px; color:var(--text); outline:none; transition:border-color var(--ease); }
.bar-note:focus { border-color:var(--accent2); }
.bar-note::placeholder { color:var(--text3); }
.btn-finish {
  display:inline-flex; align-items:center; gap:7px;
  background:var(--accent); color:#fff; border:none; border-radius:50px;
  padding:10px 20px; font-family:'Golos Text',sans-serif; font-size:13px; font-weight:600;
  cursor:pointer; white-space:nowrap;
  box-shadow:0 4px 14px rgba(45,90,61,.3); transition:background var(--ease), transform .15s;
}
.btn-finish:hover { background:#234830; transform:translateY(-1px); }

.cal-top {
  display:flex; align-items:center; gap:10px;
  padding:14px 0 12px; border-bottom:1px solid var(--surface2); margin-bottom:14px;
}
.cal-month { font-family:'Unbounded',sans-serif; font-size:18px; font-weight:600; flex:1; text-align:center; }
.cal-nav-btn {
  width:34px; height:34px; border-radius:50%;
  background:var(--surface); border:2px solid var(--surface2);
  cursor:pointer; display:flex; align-items:center; justify-content:center; color:var(--text2); flex-shrink:0;
  transition:background var(--ease), border-color var(--ease), color var(--ease);
}
.cal-nav-btn:hover { background:var(--accent); border-color:var(--accent); color:#fff; }
.cal-today { padding:7px 14px; border-radius:50px; background:var(--surface2); border:none; font-family:'Golos Text',sans-serif; font-size:12px; font-weight:600; color:var(--text2); cursor:pointer; transition:background var(--ease),color var(--ease); }
.cal-today:hover { background:var(--accent); color:#fff; }

.cal-grid { display:grid; grid-template-columns:repeat(7,1fr); gap:5px; }
.cal-wd { text-align:center; font-size:10px; font-weight:600; text-transform:uppercase; letter-spacing:.7px; color:var(--text3); padding-bottom:8px; }
.cal-wd.wknd { color:var(--accent3); }

.cal-cell {
  background:var(--surface); border-radius:10px; min-height:82px; padding:7px;
  cursor:pointer; border:2px solid transparent; box-shadow:var(--shadow);
  transition:border-color var(--ease), box-shadow var(--ease);
}
.cal-cell:hover { border-color:var(--accent2); box-shadow:var(--shadow-hover); }
.cal-cell.other { background:transparent; box-shadow:none; opacity:.35; pointer-events:none; }
.cal-cell.today { border-color:var(--accent); }
.cal-cell.wknd .cal-dn { color:var(--accent3); }

.cal-dn { font-family:'Unbounded',sans-serif; font-size:12px; font-weight:600; color:var(--text2); margin-bottom:5px; line-height:1; }
.cal-cell.today .cal-dn { color:#fff; background:var(--accent); width:22px; height:22px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:10px; }

.cal-ev { font-size:9px; font-weight:500; padding:2px 6px 2px 4px; border-radius:5px; background:rgba(122,176,138,.2); color:var(--accent); margin-bottom:2px; display:flex; align-items:center; gap:3px; overflow:hidden; white-space:nowrap; }
.cal-ev.past { background:var(--surface2); color:var(--text3); }
.ev-n { background:var(--accent); color:#fff; border-radius:3px; padding:0 3px; font-size:8px; font-weight:700; flex-shrink:0; }
.cal-ev.past .ev-n { background:var(--text3); }

.cal-overlay {
  position:fixed; inset:0; background:rgba(26,26,24,.4); backdrop-filter:blur(4px);
  z-index:500; display:flex; align-items:flex-end; justify-content:flex-end; padding:20px;
  opacity:0; pointer-events:none; transition:opacity .3s;
}
.cal-overlay.open { opacity:1; pointer-events:all; }
.cal-side {
  background:var(--surface); border-radius:18px; width:360px; max-height:78vh;
  overflow-y:auto; overflow-x:hidden;
  padding:24px; position:relative;
  transform:translateX(30px); transition:transform var(--ease);
  box-shadow:0 20px 70px rgba(0,0,0,.18);
}
.cal-overlay.open .cal-side { transform:translateX(0); }
.cal-side-hd { font-family:'Unbounded',sans-serif; font-size:14px; font-weight:600; margin-bottom:16px; text-transform:capitalize; }
.cal-side-sub { font-size:10px; font-weight:600; text-transform:uppercase; letter-spacing:.8px; color:var(--accent); margin:14px 0 9px; }
.cal-close { position:absolute; top:18px; right:18px; width:28px; height:28px; border-radius:50%; border:none; background:var(--surface2); cursor:pointer; display:flex; align-items:center; justify-content:center; color:var(--text2); transition:background .15s,color .15s; }
.cal-close:hover { background:var(--danger); color:#fff; }

.appt-item { display:flex; align-items:center; gap:10px; padding:10px 12px; border-radius:var(--r-sm); background:var(--bg); margin-bottom:6px; border:1px solid var(--surface2); }
.appt-time { font-family:'Unbounded',sans-serif; font-size:11px; font-weight:600; color:var(--accent); min-width:38px; }
.appt-info { flex:1; min-width:0; }
.appt-name { font-size:12px; font-weight:600; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.appt-badge { font-size:10px; color:var(--text3); margin-top:1px; }
.appt-badge strong { color:var(--accent); }
.appt-del { width:24px; height:24px; border-radius:50%; border:none; background:transparent; cursor:pointer; display:flex; align-items:center; justify-content:center; color:var(--text3); transition:background .15s,color .15s; flex-shrink:0; }
.appt-del:hover { background:rgba(192,57,43,.12); color:var(--danger); }
.no-appts { text-align:center; padding:16px; color:var(--text3); font-size:12px; border:2px dashed var(--surface2); border-radius:var(--r-sm); margin-bottom:4px; }

.cal-form { display:flex; flex-direction:column; gap:8px; }
.cal-form-row { display:grid; grid-template-columns:1fr 1fr; gap:8px; }
.cal-form label { font-size:11px; font-weight:500; color:var(--text2); display:block; margin-bottom:4px; }
.cal-form input, .cal-form select { width:100%; padding:9px 11px; border-radius:var(--r-sm); border:2px solid var(--surface2); background:var(--bg); font-family:'Golos Text',sans-serif; font-size:13px; color:var(--text); outline:none; transition:border-color var(--ease); }
.cal-form input:focus, .cal-form select:focus { border-color:var(--accent2); }
.cal-form-add { width:100%; padding:11px; border-radius:50px; border:none; background:var(--accent); color:#fff; font-family:'Golos Text',sans-serif; font-size:13px; font-weight:600; cursor:pointer; margin-top:2px; box-shadow:0 4px 14px rgba(45,90,61,.25); transition:background var(--ease),transform .15s; }
.cal-form-add:hover { background:#234830; transform:translateY(-1px); }

.modal-overlay { position:fixed; inset:0; background:rgba(26,26,24,.45); backdrop-filter:blur(4px); z-index:400; display:flex; align-items:center; justify-content:center; padding:24px; opacity:0; pointer-events:none; transition:opacity .3s; }
.modal-overlay.open { opacity:1; pointer-events:all; }
.modal { background:var(--surface); border-radius:20px; width:100%; max-width:560px; max-height:88vh; overflow-y:auto; overflow-x:hidden; padding:28px; transform:translateY(16px) scale(.97); transition:transform .35s cubic-bezier(.4,0,.2,1); box-shadow:0 24px 80px rgba(0,0,0,.18); }
.modal-overlay.open .modal { transform:translateY(0) scale(1); }
.modal-title { font-family:'Unbounded',sans-serif; font-size:16px; font-weight:600; margin-bottom:20px; }
.form-section { font-size:10px; font-weight:600; text-transform:uppercase; letter-spacing:.8px; color:var(--accent); margin:18px 0 10px; }
.form-group { margin-bottom:12px; }
.form-group label { display:block; font-size:12px; font-weight:500; color:var(--text2); margin-bottom:5px; }
.form-control { width:100%; padding:11px 13px; border-radius:var(--r-sm); border:2px solid var(--surface2); background:var(--bg); font-family:'Golos Text',sans-serif; font-size:13px; color:var(--text); outline:none; transition:border-color var(--ease); }
.form-control:focus { border-color:var(--accent2); }
.form-control::placeholder { color:var(--text3); }
textarea.form-control { resize:vertical; min-height:75px; }
.form-row { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
.modal-footer { display:flex; justify-content:flex-end; gap:10px; margin-top:20px; padding-top:18px; border-top:1px solid var(--surface2); }
.btn-save { padding:11px 22px; border-radius:50px; border:none; background:var(--accent); color:#fff; font-family:'Golos Text',sans-serif; font-size:13px; font-weight:600; cursor:pointer; box-shadow:0 4px 14px rgba(45,90,61,.25); transition:background var(--ease),transform .15s; }
.btn-save:hover { background:#234830; transform:translateY(-1px); }

::-webkit-scrollbar { width:5px; }
::-webkit-scrollbar-track { background:transparent; }
::-webkit-scrollbar-thumb { background:var(--surface2); border-radius:3px; }

.sidebar-overlay {
  position:fixed; inset:0;
  background:rgba(26,26,24,0);
  z-index:700;
  pointer-events:none;
  transition:background .35s;
}
.sidebar-overlay.open {
  background:rgba(26,26,24,.35);
  pointer-events:all;
}

.sidebar {
  position:fixed; top:0; left:0; bottom:0;
  width:280px;
  background:var(--surface);
  display:flex; flex-direction:column;
  z-index:701;
  transform:translateX(-100%);
  transition:transform .4s cubic-bezier(0.4,0,0.2,1);
  box-shadow:8px 0 40px rgba(0,0,0,0);
  border-radius:0 20px 20px 0;
  overflow:hidden;
}
.sidebar-overlay.open .sidebar {
  transform:translateX(0);
  box-shadow:8px 0 40px rgba(0,0,0,.15);
}

.sidebar-head {
  padding:20px 20px 16px;
  border-bottom:1px solid var(--surface2);
  display:flex; align-items:center; justify-content:space-between;
  flex-shrink:0;
}
.sidebar-logo { font-family:'Unbounded',sans-serif; font-size:16px; font-weight:600; color:var(--accent); letter-spacing:-.5px; }
.sidebar-logo span { color:var(--text3); font-weight:300; }
.sidebar-close {
  width:30px; height:30px; border-radius:50%;
  border:none; background:var(--surface2);
  cursor:pointer; display:flex; align-items:center; justify-content:center;
  color:var(--text2); transition:background var(--ease), color var(--ease);
  flex-shrink:0;
}
.sidebar-close:hover { background:var(--surface2); color:var(--danger); }

.sidebar-body { flex:1; overflow-y:auto; padding:14px 12px 20px; }

.sb-item {
  display:flex; align-items:center; gap:12px;
  padding:11px 12px; border-radius:12px;
  cursor:pointer; border:none; background:transparent;
  font-family:'Golos Text',sans-serif; font-size:14px; font-weight:500;
  color:var(--text2); width:100%; text-align:left;
  transition:background var(--ease), color var(--ease), transform .15s;
  position:relative;
  animation:sbItemIn .3s ease both;
}
.sb-item:hover { background:var(--bg); color:var(--text); transform:translateX(3px); }
.sb-item.active-item { background:rgba(45,90,61,.1); color:var(--accent); }
.sb-item svg { flex-shrink:0; opacity:.7; transition:opacity var(--ease); }
.sb-item:hover svg, .sb-item.active-item svg { opacity:1; }

.sb-item:nth-child(1){animation-delay:.05s}
.sb-item:nth-child(2){animation-delay:.10s}
.sb-item:nth-child(3){animation-delay:.15s}

.archive-card {
  background:var(--surface); border-radius:var(--r); padding:20px;
  cursor:pointer; border:2px solid rgba(192,57,43,.15);
  box-shadow:var(--shadow); animation:fadeUp .35s ease both;
  transition:border-color var(--ease), box-shadow var(--ease), transform var(--ease);
  opacity:.85;
}
.archive-card:hover { border-color:rgba(192,57,43,.4); box-shadow:var(--shadow-hover); transform:translateY(-2px); opacity:1; }
.archive-card .client-avatar { background:linear-gradient(135deg,#c0392b,#8e1c11); }

.sess-tabs {
  display:flex; gap:6px; flex-wrap:wrap;
  padding:18px 0 16px;
  border-bottom:1px solid var(--surface2);
  margin-bottom:20px;
}
.sess-tab {
  padding:8px 16px; border-radius:50px;
  border:2px solid var(--surface2);
  background:var(--surface);
  font-family:'Golos Text',sans-serif; font-size:13px; font-weight:500; color:var(--text2);
  cursor:pointer; transition:all var(--ease);
}
.sess-tab:hover { border-color:var(--accent2); color:var(--accent); }
.sess-tab.active { background:var(--accent); border-color:var(--accent); color:#fff; }

.sess-tab-body { animation:fadeUp .3s ease both; }
.sess-tab-body.hidden { display:none; }

.smr-grid { display:grid; grid-template-columns:1fr 1fr; gap:14px; }
.smr-card {
  background:var(--surface); border-radius:var(--r); padding:18px;
  box-shadow:var(--shadow); border:2px solid transparent;
  transition:border-color var(--ease);
}
.smr-card:focus-within { border-color:var(--accent2); }
.smr-card-accent { background:linear-gradient(135deg,rgba(45,90,61,.04),var(--surface)); border-color:rgba(45,90,61,.15); }
.smr-card-red { background:linear-gradient(135deg,rgba(192,57,43,.04),var(--surface)); }

.smr-label {
  font-family:'Unbounded',sans-serif; font-size:11px; font-weight:600;
  color:var(--text2); margin-bottom:10px; letter-spacing:.2px;
}
.smr-sublabel {
  font-size:10px; font-weight:600; color:var(--text3);
  text-transform:uppercase; letter-spacing:.6px;
  margin:10px 0 6px;
}
.smr-input {
  width:100%; min-height:110px;
  background:var(--bg); border:none; border-radius:var(--r-sm);
  padding:10px 12px; resize:vertical;
  font-family:'Golos Text',sans-serif; font-size:13px; color:var(--text); line-height:1.6;
  outline:none; transition:box-shadow var(--ease);
}
.smr-input:focus { box-shadow:0 0 0 2px var(--accent2); }
.smr-input::placeholder { color:var(--text3); }

.quick-intro {
  background:rgba(45,90,61,.08); border-left:3px solid var(--accent);
  border-radius:0 var(--r-sm) var(--r-sm) 0;
  padding:12px 16px; margin-bottom:18px;
  font-size:13px; color:var(--text2); line-height:1.5;
}

.sess-finish-bar {
  position:sticky; bottom:0; left:0; right:0;
  background:var(--bg); border-top:2px solid var(--accent2);
  padding:14px 0 10px;
  display:flex; align-items:center; gap:14px;
  margin-top:24px;
  z-index:10;
}

.test-overlay {
  position:fixed; inset:0; background:rgba(26,26,24,.5); backdrop-filter:blur(6px);
  z-index:600; display:flex; align-items:center; justify-content:center; padding:24px;
  opacity:0; pointer-events:none; transition:opacity .3s;
}
.test-overlay.open { opacity:1; pointer-events:all; }
.test-modal {
  background:var(--surface); border-radius:22px;
  width:100%; max-width:620px; max-height:88vh; overflow-y:auto; overflow-x:hidden;
  box-shadow:0 32px 96px rgba(0,0,0,.22);
  transform:scale(.93) translateY(20px); opacity:0;
  transition:transform .4s cubic-bezier(.34,1.2,.64,1), opacity .3s;
}
.test-overlay.open .test-modal { transform:scale(1) translateY(0); opacity:1; }
.test-header {
  background:linear-gradient(135deg,#2d5a3d,#1a3d28);
  border-radius:22px 22px 0 0; padding:24px 28px 20px;
  position:relative;
}
.test-header-title { font-family:'Unbounded',sans-serif; font-size:18px; font-weight:600; color:#fff; margin-bottom:4px; }
.test-header-sub { font-size:13px; color:rgba(255,255,255,.7); }
.test-close {
  position:absolute; top:18px; right:18px;
  width:30px; height:30px; border-radius:50%; border:none;
  background:rgba(255,255,255,.15); cursor:pointer;
  display:flex; align-items:center; justify-content:center; color:#fff;
  transition:background .2s;
}
.test-close:hover { background:rgba(255,255,255,.3); }
.test-body { padding:24px 28px 28px; }
.test-q { margin-bottom:16px; }
.test-q-text { font-size:14px; color:var(--text); margin-bottom:8px; line-height:1.5; }
.test-options { display:flex; flex-direction:column; gap:6px; }
.test-opt {
  display:flex; align-items:center; gap:10px;
  padding:10px 14px; border-radius:var(--r-sm);
  background:var(--bg); border:2px solid transparent;
  cursor:pointer; transition:all var(--ease);
  font-size:13px; color:var(--text2);
}
.test-opt:hover { border-color:var(--accent2); color:var(--text); }
.test-opt.selected { border-color:var(--accent); background:rgba(45,90,61,.08); color:var(--accent); font-weight:600; }
.test-opt-score { font-family:'Unbounded',sans-serif; font-size:10px; color:var(--text3); margin-left:auto; }
.test-result {
  background:linear-gradient(135deg,rgba(45,90,61,.08),rgba(45,90,61,.02));
  border:2px solid rgba(45,90,61,.2); border-radius:var(--r);
  padding:20px; text-align:center; margin-top:20px;
}
.test-result-score { font-family:'Unbounded',sans-serif; font-size:36px; font-weight:600; color:var(--accent); }
.test-result-label { font-size:15px; font-weight:600; color:var(--text); margin:6px 0 4px; }
.test-result-range { font-size:12px; color:var(--text3); }
.test-progress { display:flex; gap:4px; margin-top:16px; }
.test-progress-bar { flex:1; height:4px; border-radius:2px; background:var(--surface2); transition:background .3s; }
.test-progress-bar.done { background:var(--accent2); }
.test-progress-bar.active { background:var(--accent); }

@keyframes sbItemIn {
  from { opacity:0; transform:translateX(-12px); }
  to   { opacity:1; transform:translateX(0); }
}

.sb-divider {
  height:1px; background:var(--surface2);
  margin:10px 4px; animation:sbItemIn .3s ease both;
}

.sb-section-label {
  font-family:'Unbounded',sans-serif; font-size:9px; font-weight:600;
  text-transform:uppercase; letter-spacing:.8px; color:var(--text3);
  padding:8px 12px 4px;
  animation:sbItemIn .3s ease both;
}

.menu-btn {
  width:34px; height:34px; border-radius:50%;
  background:transparent; border:none;
  cursor:pointer; display:flex; align-items:center; justify-content:center;
  color:var(--accent); flex-shrink:0;
  transition:background var(--ease), transform .2s;
}
.menu-btn:hover { background:var(--surface2); transform:scale(1.1); }

@media(max-width:860px){ .technique-grid{grid-template-columns:repeat(2,1fr);} }
@media(max-width:600px){ .screen-body{padding:0 16px 60px;} .topbar{padding:14px 16px;} .client-grid{grid-template-columns:1fr;} .form-row{grid-template-columns:1fr;} .cal-side{width:100%;} .sidebar{width:260px;} .smr-grid{grid-template-columns:1fr;} }
</style>
</head>
<body>

<!-- SCREEN 1: CLIENTS -->
<div class="screen active" id="s-clients">
  <div class="topbar">
    <button class="menu-btn" onclick="UIController.openSidebar()">
      <svg width="19" height="19" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
    <div class="logo">КПТ<span>шка</span></div>
    <div class="spacer"></div>
    <button class="btn-primary" onclick="UIController.openClientModal()">
      <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>
      Новый клиент
    </button>
  </div>
  <div class="screen-body">
    <div class="page-header">
      <div>
        <div class="page-title">Картотека клиентов</div>
        <div class="page-subtitle" id="client-count-label">0 клиентов</div>
      </div>
    </div>
    <div class="search-wrap">
      <svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      <input class="search-input" placeholder="Поиск…" oninput="ClientController.filterClients(this.value)">
    </div>
    <div class="client-grid" id="client-grid"></div>
  </div>
</div>

<!-- SCREEN 2: PROFILE -->
<div class="screen" id="s-profile">
  <div class="topbar">
    <button class="back-btn" onclick="NavController.navBack('s-clients')">
      <svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="m15 18-6-6 6-6"/></svg>
    </button>
    <div class="topbar-title">Профиль</div>
    <div class="spacer"></div>
  </div>
  <div class="screen-body" id="profile-content"></div>
</div>

<!-- SCREEN 3: SESSION -->
<div class="screen" id="s-session">
  <div class="topbar">
    <button class="back-btn" onclick="NavController.navBack('s-profile')">
      <svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="m15 18-6-6 6-6"/></svg>
    </button>
    <div class="topbar-title" id="session-title">Сессия</div>
    <div class="spacer"></div>
    <div style="font-family:'Unbounded',sans-serif;font-size:11px;color:var(--accent);background:rgba(45,90,61,.1);padding:5px 12px;border-radius:50px;" id="session-num-badge"></div>
  </div>
  <div class="screen-body" style="padding-bottom:80px">

    <div class="sess-tabs">
      <button class="sess-tab active" onclick="SessionUI.switchSessTab(this,'tab-smr')">📝 СМЭР</button>
      <button class="sess-tab" onclick="SessionUI.switchSessTab(this,'tab-quick')">⚡ Быстрая помощь</button>
      <button class="sess-tab" onclick="SessionUI.switchSessTab(this,'tab-notes')">💬 Заметки</button>
      <button class="sess-tab" onclick="SessionUI.switchSessTab(this,'tab-plan')">🎯 ДЗ и план</button>
    </div>

    <!-- TAB 1: СМЭР -->
    <div class="sess-tab-body" id="tab-smr">
      <div class="smr-grid">
        <div class="smr-card">
          <div class="smr-label">🔴 Ситуация / Триггер</div>
          <textarea class="smr-input" id="smr-situation" placeholder="Где, когда, с кем? Что произошло?"></textarea>
        </div>
        <div class="smr-card">
          <div class="smr-label">💭 Автоматические мысли</div>
          <textarea class="smr-input" id="smr-thoughts" placeholder="Что пронеслось в голове?"></textarea>
        </div>
        <div class="smr-card">
          <div class="smr-label">😟 Эмоции (0–10)</div>
          <textarea class="smr-input" id="smr-emotions" placeholder="Какие эмоции? Оцените интенсивность"></textarea>
          <div class="smr-sublabel">Физ. ощущения</div>
          <textarea class="smr-input" id="smr-body" placeholder="Напряжение, дрожь, сердцебиение…" style="min-height:70px"></textarea>
        </div>
        <div class="smr-card">
          <div class="smr-label">🏃 Реакция / Поведение</div>
          <textarea class="smr-input" id="smr-behavior" placeholder="Что сделали? Как повели(ась)?"></textarea>
        </div>
        <div class="smr-card">
          <div class="smr-label">🔗 Промежуточное убеждение (ПУ)</div>
          <textarea class="smr-input" id="smr-pu" placeholder="Правило: «Я должна…», Предположение: «Если…, то…»"></textarea>
        </div>
        <div class="smr-card smr-card-accent">
          <div class="smr-label">⚡ Глубинное убеждение (ГУ)</div>
          <textarea class="smr-input" id="smr-gu" placeholder="«Я плохая», «Я ненужная», «Я недостаточно хорошая»"></textarea>
        </div>
      </div>
      <div style="margin-top:16px;display:flex;gap:10px;justify-content:flex-end">
        <button class="btn-ghost" onclick="SessionUI.clearSMR()" style="font-size:12px;padding:8px 16px">Очистить</button>
        <button class="btn-primary" onclick="SessionUI.saveSMRToSession()" style="font-size:13px;padding:9px 18px">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
          Сохранить в сессию
        </button>
      </div>
    </div>

    <!-- TAB 2: Быстрая помощь -->
    <div class="sess-tab-body hidden" id="tab-quick">
      <div class="quick-intro">
        <b>Протокол «Быстрая помощь»</b> — работа с глубинным убеждением прямо на сессии
      </div>
      <div class="smr-grid">
        <div class="smr-card">
          <div class="smr-label">📌 Ситуация</div>
          <textarea class="smr-input" id="q-situation" placeholder="Конкретная ситуация…"></textarea>
        </div>
        <div class="smr-card">
          <div class="smr-label">💭 Мысли → Эмоции → Реакции</div>
          <textarea class="smr-input" id="q-thoughts" placeholder="Мысли и их интенсивность…"></textarea>
        </div>
        <div class="smr-card smr-card-red">
          <div class="smr-label">❌ ГУ минус (негативное убеждение)</div>
          <textarea class="smr-input" id="q-gu-minus" placeholder="«Я плохая/ой» — на сколько баллов?"></textarea>
          <div style="margin-top:8px">
            <div class="smr-sublabel">По какой ДРУГОЙ причине, кроме как я плохой?</div>
            <textarea class="smr-input" id="q-other-reasons" placeholder="Другие объяснения ситуации…" style="min-height:70px"></textarea>
          </div>
        </div>
        <div class="smr-card smr-card-accent">
          <div class="smr-label">✅ ГУ плюс (новое убеждение)</div>
          <textarea class="smr-input" id="q-gu-plus" placeholder="«Я достаточно хорошая — на 8/10»…" style="min-height:80px"></textarea>
        </div>
      </div>
      <div style="margin-top:16px;display:flex;gap:10px;justify-content:flex-end">
        <button class="btn-ghost" onclick="SessionUI.clearQuick()" style="font-size:12px;padding:8px 16px">Очистить</button>
        <button class="btn-primary" onclick="SessionUI.saveQuickToSession()" style="font-size:13px;padding:9px 18px">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
          Сохранить в сессию
        </button>
      </div>
    </div>

    <!-- TAB 3: Заметки -->
    <div class="sess-tab-body hidden" id="tab-notes">
      <div class="smr-card" style="margin-bottom:16px">
        <div class="smr-label">📋 Заметки психолога</div>
        <textarea class="smr-input" id="sess-notes-text" placeholder="Свободные заметки по ходу сессии…" style="min-height:200px"></textarea>
      </div>
      <div class="smr-card">
        <div class="smr-label">🔑 Ключевые темы и паттерны</div>
        <textarea class="smr-input" id="sess-patterns" placeholder="Повторяющиеся паттерны, связи с ГУ…" style="min-height:120px"></textarea>
      </div>
      <div style="margin-top:16px;display:flex;justify-content:flex-end">
        <button class="btn-primary" onclick="SessionUI.saveNotesToSession()" style="font-size:13px;padding:9px 18px">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
          Сохранить в сессию
        </button>
      </div>
    </div>

    <!-- TAB 4: ДЗ и план -->
    <div class="sess-tab-body hidden" id="tab-plan">
      <div class="smr-card" style="margin-bottom:16px">
