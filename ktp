// SESSION UI — Работа с сессиями
// ═════════════════════════════════════════════════════════════════════════════════════

const SessionUI = {
  currentClient: null,
  currentData: {},

  startSession(idx) {
    this.currentClient = idx;
    this.currentData = {};
    const c = ClientController.clients[idx];
    const sessCount = Storage.getSessions().filter(s => s.clientIdx === idx).length + 1;
    document.getElementById('session-title').textContent = `Сессия · ${c.name}`;
    document.getElementById('session-num-badge').textContent = `Сессия №${sessCount}`;

    document.querySelectorAll('.sess-tab').forEach((t,i)=>t.classList.toggle('active',i===0));
    document.querySelectorAll('.sess-tab-body').forEach((t,i)=>t.classList.toggle('hidden',i!==0));

    NavController.navTo('s-session');
  },

  switchSessTab(btn,tabId) {
    document.querySelectorAll('.sess-tab').forEach(t=>t.classList.remove('active'));
    document.querySelectorAll('.sess-tab-body').forEach(t=>t.classList.add('hidden'));
    btn.classList.add('active');
    document.getElementById(tabId).classList.remove('hidden');
  },

  saveSMRToSession() {
    this.currentData.smr = {
      situation: document.getElementById('smr-situation').value,
      thoughts: document.getElementById('smr-thoughts').value,
      emotions: document.getElementById('smr-emotions').value,
      body: document.getElementById('smr-body').value,
      behavior: document.getElementById('smr-behavior').value,
      pu: document.getElementById('smr-pu').value,
      gu: document.getElementById('smr-gu').value,
    };
    UIController.showToast('✓ СМЭР сохранён');
  },

  clearSMR() {
    ['smr-situation','smr-thoughts','smr-emotions','smr-body','smr-behavior','smr-pu','smr-gu'].forEach(id=>document.getElementById(id).value='');
  },

  saveQuickToSession() {
    this.currentData.quick = {
      situation: document.getElementById('q-situation').value,
      thoughts: document.getElementById('q-thoughts').value,
      guMinus: document.getElementById('q-gu-minus').value,
      otherReasons: document.getElementById('q-other-reasons').value,
      guPlus: document.getElementById('q-gu-plus').value,
    };
    UIController.showToast('✓ Быстрая помощь сохранена');
  },

  clearQuick() {
    ['q-situation','q-thoughts','q-gu-minus','q-other-reasons','q-gu-plus'].forEach(id=>document.getElementById(id).value='');
  },

  saveNotesToSession() {
    this.currentData.notes = document.getElementById('sess-notes-text').value;
    this.currentData.patterns = document.getElementById('sess-patterns').value;
    UIController.showToast('✓ Заметки сохранены');
  },

  finishFullSession() {
    const notes = [
      this.currentData.notes && `${this.currentData.notes}`,
      document.getElementById('sess-homework').value && `ДЗ: ${document.getElementById('sess-homework').value}`,
      document.getElementById('sess-feedback').value && `ОС: ${document.getElementById('sess-feedback').value}`,
    ].filter(Boolean).join('\n\n');

    const sess = {
      clientIdx: this.currentClient,
      date: new Date().toISOString(),
      techniques: [],
      note: notes || document.getElementById('sess-next').value || '',
      smr: this.currentData.smr || null,
      quick: this.currentData.quick || null,
    };

    const sessions = Storage.getSessions();
    sessions.push(sess);
    Storage.setSessions(sessions);

    this.currentData = {};
    ['smr-situation','smr-thoughts','smr-emotions','smr-body','smr-behavior','smr-pu','smr-gu','q-situation','q-thoughts','q-gu-minus','q-other-reasons','q-gu-plus','sess-notes-text','sess-patterns','sess-homework','sess-next','sess-feedback'].forEach(id=>{const el=document.getElementById(id);if(el)el.value=''});

    ClientController.openClient(this.currentClient);
    UIController.showToast('✓ Сессия завершена');
  },
};

