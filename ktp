<script>
// ═════════════════════════════════════════════════════════════════════════════════════
// STORAGE — ИСПРАВКА #1 — Безопасный парсинг localStorage
// ═════════════════════════════════════════════════════════════════════════════════════

const Storage = {
  get(key, defaultValue = []) {
    try {
      const data = localStorage.getItem(key);
      if (!data) return defaultValue;
      const parsed = JSON.parse(data);
      if (!Array.isArray(parsed) && Array.isArray(defaultValue)) {
        console.warn(`Storage: ${key} corrupted, using default`);
        return defaultValue;
      }
      return parsed;
    } catch (error) {
      console.error(`Storage parse error for ${key}:`, error);
      return defaultValue;
    }
  },

  set(key, value) {
    try {
      localStorage.setItem(key, JSON.stringify(value));
      return true;
    } catch (error) {
      console.error(`Storage save error for ${key}:`, error);
      return false;
    }
  },

  getClients() { return this.get('kpt_clients', []); },
  setClients(v) { return this.set('kpt_clients', v); },
  getSessions() { return this.get('kpt_sessions', []); },
  setSessions(v) { return this.set('kpt_sessions', v); },
  getAppointments() { return this.get('kpt_appointments', []); },
  setAppointments(v) { return this.set('kpt_appointments', v); },
};

// ═════════════════════════════════════════════════════════════════════════════════════
// VALIDATORS — Валидация данных
// ═════════════════════════════════════════════════════════════════════════════════════

const Validators = {
  // ИСПРАВКА #2: Безопасный расчет возраста
  calculateAge(dob) {
    if (!dob || typeof dob !== 'string') return null;
    try {
      const birthDate = new Date(dob);
      if (isNaN(birthDate.getTime())) return null;
      const age = Math.floor((Date.now() - birthDate) / (365.25 * 24 * 60 * 60 * 1000));
      if (age < 0 || age > 150) return null;
      return age;
    } catch (e) {
      return null;
    }
  },

  // ИСПРАВКА #3: Защита доступа к массиву
  isValidClientIndex(idx, clients) {
    return typeof idx === 'number' && idx >= 0 && idx < clients.length && clients[idx] !== null;
  },

  // ИСПРАВКА #4: Валидация формы
  validateClientForm() {
    const name = document.getElementById('f-name').value.trim();
    if (!name) {
      UIController.showToast('❌ Введите имя клиента');
      document.getElementById('f-name').focus();
      return false;
    }
    return true;
  },
};

// ═════════════════════════════════════════════════════════════════════════════════════
// HELPERS — Утилиты
// ═════════════════════════════════════════════════════════════════════════════════════

const Helpers = {
  ini(c) { return ((c.name[0]||'')+(c.surname?.[0]||'')).toUpperCase()||'?'; },
  declination(n,a,b,c) { if(n%10===1&&n%100!==11)return a; if([2,3,4].includes(n%10)&&![12,13,14].includes(n%100))return b; return c; },
  fmtDate(iso) {
    if (!iso) return '';
    try {
      const d = new Date(iso);
      if (isNaN(d.getTime())) return '';
      return d.toLocaleDateString('ru-RU', {day:'numeric',month:'long',year:'numeric',hour:'2-digit',minute:'2-digit'});
    } catch (e) {
      return '';
    }
  },
  truncate(t,n) { return !t||t.length<=n?t:t.slice(0,n)+'…'; },
};

// ═════════════════════════════════════════════════════════════════════════════════════
// NAV CONTROLLER — Навигация
// ═════════════════════════════════════════════════════════════════════════════════════

const NavController = {
  stack: ['s-clients'],

  navTo(id) {
    const cur = this.stack[this.stack.length - 1];
    if (cur === id) return;
    document.getElementById(cur).classList.add('behind');
    document.getElementById(id).classList.remove('behind');
    document.getElementById(id).classList.add('active');
    this.stack.push(id);
    const body = document.getElementById(id).querySelector('.screen-body');
    if (body) body.scrollTo(0, 0);
  },

  navBack(to) {
    const cur = this.stack[this.stack.length - 1];
    document.getElementById(cur).classList.remove('active');
    document.getElementById(to).classList.remove('behind');
    const idx = this.stack.lastIndexOf(to);
    this.stack.splice(idx + 1);
  },
};

// ═════════════════════════════════════════════════════════════════════════════════════
// CLIENT CONTROLLER — Управление клиентами
// ═════════════════════════════════════════════════════════════════════════════════════

const ClientController = {
  clients: [],

  init() {
    this.clients = Storage.getClients();
    if (this.clients.length === 0) {
      this.loadDemoData();
    }
    this.render();
  },

  // ИСПРАВКА #3: Защита openClient
  openClient(idx) {
    if (!Validators.isValidClientIndex(idx, this.clients)) {
      UIController.showToast('❌ Клиент не найден');
      this.render();
      return;
    }

    const c = this.clients[idx];
    const age = Validators.calculateAge(c.dob);
    const sc = Storage.getSessions().filter(s => s.clientIdx === idx).length;
    const ageText = age ? `${age} ${Helpers.declination(age,'год','года','лет')}` : '';
    
    document.getElementById('profile-content').innerHTML = `
      <div class="profile-hero">
        <div class="profile-avatar">${Helpers.ini(c)}</div>
        <div class="profile-hero-info">
          <div class="profile-name">${c.name}${c.surname?' '+c.surname:''}</div>
          <div class="profile-sub">${ageText}${c.gender?' · '+c.gender:''}${sc?' · '+sc+' сессий':''}</div>
        </div>
        ${c.archived
          ? `<button onclick="UIController.confirmRestore(${idx})" class="btn-session">Вернуть</button>`
          : `<button class="btn-session" onclick="SessionUI.startSession(${idx})">Начать сессию</button>
             <button onclick="UIController.confirmArchive(${idx})" style="background:transparent;color:var(--danger);border:2px solid rgba(192,57,43,.3);margin-left:10px">Архив</button>`
        }
      </div>
      <div class="section-title">Контакты</div>
      <div class="fields-grid">${this.field('Телефон',c.phone)}${this.field('Email',c.email)}</div>
      <div class="section-title">Запрос и анамнез</div>
      <div class="fields-grid">${this.field('Жалобы',c.complaint,true)}${this.field('История',c.history,true)}${this.field('Диагноз',c.diagnosis)}</div>
      <div class="section-title">Цели терапии</div>
      <div class="fields-grid">${this.field('Цели',c.goals,true)}${this.field('Опыт',c.prev)}</div>
      <div class="section-title">Дополнительно</div>
      <div class="fields-grid">${this.field('Препараты',c.meds)}${this.field('Заметки',c.notes,true)}</div>
      <div class="section-title">История сессий</div>
      ${Storage.getSessions().filter(s=>s.clientIdx===idx).length
        ? Storage.getSessions().filter(s=>s.clientIdx===idx).sort((a,b)=>new Date(b.date)-new Date(a.date)).map((s,i)=>`
          <div class="session-item">
            <div class="session-item-head">
              <div class="session-item-date">${Helpers.fmtDate(s.date)}</div>
            </div>
            <div class="session-item-techs">${(s.techniques||[]).map(t=>`<span class="tag green">${t}</span>`).join('')}</div>
            ${s.note?`<div class="session-item-note">${s.note}</div>`:''}
          </div>`).join('')
        : '<div class="no-sessions">Сессий пока не было</div>'
      }
    `;
    NavController.navTo('s-profile');
  },

  field(label, val, wide=false) {
    return `<div class="field-card${wide?' wide':''}"><div class="field-label">${label}</div><div class="field-value${val?'':' empty'}">${val||'Не заполнено'}</div></div>`;
  },

  saveClient() {
    if (!Validators.validateClientForm()) return;

    const client = {
      name: document.getElementById('f-name').value.trim(),
      surname: document.getElementById('f-surname').value.trim(),
      dob: document.getElementById('f-dob').value,
      gender: document.getElementById('f-gender').value,
      phone: document.getElementById('f-phone').value.trim(),
      email: document.getElementById('f-email').value.trim(),
      complaint: document.getElementById('f-complaint').value.trim(),
      history: document.getElementById('f-history').value.trim(),
      diagnosis: document.getElementById('f-diagnosis').value.trim(),
      goals: document.getElementById('f-goals').value.trim(),
      prev: document.getElementById('f-prev').value.trim(),
      meds: document.getElementById('f-meds').value.trim(),
      notes: document.getElementById('f-notes').value.trim(),
      created: new Date().toISOString(),
      archived: false,
    };

    this.clients.push(client);
    Storage.setClients(this.clients);
    UIController.closeClientModal();
    this.clearForm();
    this.render();
    UIController.showToast(`✓ ${client.name} добавлен(а)`);
  },

  filterClients(q) {
    q = q.toLowerCase();
    const active = this.clients.filter(c => !c.archived);
    const filtered = active.filter(c =>
      (c.name + ' ' + (c.surname || '')).toLowerCase().includes(q) ||
      (c.complaint || '').toLowerCase().includes(q) ||
      (c.diagnosis || '').toLowerCase().includes(q)
    );
    this.render(filtered);
  },

  render(list) {
    const active = this.clients.filter(c => !c.archived);
    const displayList = (list || active).filter(c => !c.archived);

    document.getElementById('client-count-label').textContent =
      `${active.length} ${Helpers.declination(active.length, 'клиент', 'клиента', 'клиентов')}`;

    const grid = document.getElementById('client-grid');
    if (!displayList.length) {
      grid.innerHTML = `<div class="empty-state">
        <svg width="52" height="52" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
        <p>${active.length ? 'Ничего не найдено' : 'Добавьте первого клиента'}</p>
      </div>`;
      return;
    }

    grid.innerHTML = displayList.map((c, i) => {
      const idx = this.clients.indexOf(c);
      const age = Validators.calculateAge(c.dob);
      const sc = Storage.getSessions().filter(s => s.clientIdx === idx).length;
      const tags = [c.diagnosis&&{t:c.diagnosis,g:true}, c.gender&&{t:c.gender,g:false}].filter(Boolean);
      return `<div class="client-card" onclick="ClientController.openClient(${idx})">
        <div class="client-avatar">${Helpers.ini(c)}</div>
        <div class="client-name">${c.name}${c.surname?' '+c.surname:''}</div>
        <div class="client-meta">${age?age+' лет · ':''}${Helpers.truncate(c.complaint||'Нет запроса',55)}</div>
        <div class="tags">${tags.map(t=>`<span class="tag${t.g?' green':''}">${t.t}</span>`).join('')}</div>
        <div class="client-footer"><span>Сессий: <strong>${sc}</strong></span>
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg>
        </div>
      </div>`;
    }).join('');
  },

  clearForm() {
    ['f-name','f-surname','f-dob','f-gender','f-phone','f-email','f-complaint','f-history','f-diagnosis','f-goals','f-prev','f-meds','f-notes'].forEach(id=>{
      const el=document.getElementById(id);
      el.tagName==='SELECT'?el.selectedIndex=0:(el.value='');
    });
  },

  loadDemoData() {
    this.clients = [
      {
        name: 'Наташа', surname: '',
        dob: '', gender: 'Женский',
        phone: '', email: '',
